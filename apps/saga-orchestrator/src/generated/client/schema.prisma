generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Saga {
  id          String   @id @default(uuid())
  orderId     String   @unique
  status      String // STARTED, STOCK_RESERVED, COMPLETED, FAILED
  currentStep String   @default("RESERVING_STOCK") // RESERVING_STOCK, CHARGING_PAYMENT, etc.
  productId   String
  quantity    Int
  totalAmount Float
  reason      String?
  lastEventId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProcessedEvent {
  id        String   @id @default(uuid())
  eventId   String   @unique
  topic     String
  createdAt DateTime @default(now())
}
